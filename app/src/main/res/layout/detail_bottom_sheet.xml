<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:layout_constraintStart_toStartOf="parent">

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_detail_bottom_share"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:text="공유하기"

        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_detail_bottom_edit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:text="수정하기"
        app:layout_constraintTop_toBottomOf="@+id/btn_detail_bottom_share" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_detail_bottom_delete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:text="삭제하기"
        app:layout_constraintTop_toBottomOf="@+id/btn_detail_bottom_edit" />
</androidx.constraintlayout.widget.ConstraintLayout>